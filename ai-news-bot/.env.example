# ============================================================
# AI News Collector Bot - 環境変数（秘密情報）
# ============================================================
# このファイルを .env にコピーして、各値を設定してください。
# cp .env.example .env

# --- Claude API (Anthropic) [必須] ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# --- Gmail SMTP (推奨方式) ---
# Gmail アプリパスワード（16文字・スペースなし）
# 取得手順:
#   1. https://myaccount.google.com/security にアクセス
#   2. 「2段階認証プロセス」を有効化
#   3. 「アプリ パスワード」→ アプリ名「AI News Bot」で生成
#   4. 表示された16文字のパスワードを下記に設定（スペース除去）
GMAIL_APP_PASSWORD=

# --- Gmail OAuth2 (上級者向け・auth_method: oauth2 の場合) ---
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=./credentials/gmail_token.json

# --- LINE Notify (オプション) ---
LINE_NOTIFY_TOKEN=

# --- NewsAPI (オプション・追加ニュースソース) ---
NEWS_API_KEY=
